Private Sub RelationBox_Click()
    Call InitializeColumnIndex
    Dim startColLetter As String, endColLetter As String
    
    startColLetter = ColumnLetter(ColumnIndex("Rel."))
    endColLetter = ColumnLetter(ColumnIndex("Lag"))

    If RelationBox.Value = True Then
        Columns(startColLetter & ":" & endColLetter).EntireColumn.Hidden = False
        MsgBox "Start dates will be calculated based on relationship." & vbNewLine & "Default: Finish Start with Previous Activity, Lag = 0"
    Else
        Columns(startColLetter & ":" & endColLetter).EntireColumn.Hidden = True
        MsgBox "Start dates will NOT be calculated."
    End If

End Sub

Private Sub ResetButton_Click()
    Set plotWS = ThisWorkbook.Sheets("Plot")
    ResetButton.Enabled = False
    Call ClearFromJ2
    plotWS.Cells.ClearContents
End Sub

Private Sub ScheduleButton_Click()
