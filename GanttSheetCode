Private Sub RelationBox_Click()
    Call InitializeColumnIndex
    Dim startColLetter As String, endColLetter As String
    
    startColLetter = ColumnLetter(ColumnIndex("Rel."))
    endColLetter = ColumnLetter(ColumnIndex("Lag"))

    If RelationBox.Value = True Then
        Columns(startColLetter & ":" & endColLetter).EntireColumn.Hidden = False
        MsgBox "Start dates will be calculated based on relationship." & vbNewLine & "Default: Finish Start with Previous Activity, Lag = 0"
    Else
        Columns(startColLetter & ":" & endColLetter).EntireColumn.Hidden = True
        MsgBox "Start dates will NOT be calculated."
    End If

End Sub

Private Sub ResetButton_Click()
    Dim exportableSheets As Collection
    Dim sheetName As Variant
    Dim response As VbMsgBoxResult
    Dim plotWS As Worksheet

    Set exportableSheets = ExportSheetsExist()

    If exportableSheets.Count <> 0 Then
        response = MsgBox("Export Plots?", vbYesNo + vbQuestion, "Confirm Action")
        If response = vbYes Then
            Call MoveSheetsExceptSpecified
            MsgBox "Plots have been exported", vbExclamation
        Else
            For Each sheetName In exportableSheets
                Application.DisplayAlerts = False
                ThisWorkbook.Sheets(sheetName).Delete
                Application.DisplayAlerts = True
            Next sheetName
        End If
    End If

    Call InitializeColumnIndex
    On Error Resume Next
    Set plotWS = ThisWorkbook.Sheets("Plot")
    On Error GoTo 0

    If plotWS Is Nothing Then
        MsgBox "'Plot' sheet not found.", vbExclamation
        Exit Sub
    End If

    ResetButton.Enabled = False
    GraphButton.Enabled = False
    ExportPlots.Enabled = False
    Call ClearFromJ2
    plotWS.Cells.ClearContents
End Sub

