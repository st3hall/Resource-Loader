'This function will return the range of the distribution table or calendar based on the name provided. It will be used to get the correct range for the distribution values.
Function GetTableRange(rangeName As String) As Range
    Dim cell As Range
    Dim tableRange As Range
    Dim foundInDist As Boolean
    Dim foundInCal As Boolean

    foundInDist = False
    foundInCal = False

    ' Check if rangeName is in DistType
    On Error Resume Next
    For Each cell In Range("DistType")
        If StrComp(cell.Value, rangeName, vbTextCompare) = 0 Then
            foundInDist = True
            Exit For
        End If
    Next cell

    ' Check if rangeName is in CalType
    If Not foundInDist Then
        For Each cell In Range("CalType")
            If StrComp(cell.Value, rangeName, vbTextCompare) = 0 Then
                foundInCal = True
                Exit For
            End If
        Next cell
    End If
    On Error GoTo 0

    ' Assign the appropriate table range
    If foundInDist Then
        Set tableRange = ThisWorkbook.Names("DistTab").RefersToRange
        'Debug.Print "Table Range Address: " & tableRange.Address
        'Debug.Print "Sheet Name: " & tableRange.Worksheet.Name


    ElseIf foundInCal Then
        Set tableRange = ThisWorkbook.Names("Calendar").RefersToRange
        'Debug.Print "Table Range Address: " & tableRange.Address
        'Debug.Print "Sheet Name: " & tableRange.Worksheet.Name

    Else
        Set tableRange = Nothing ' Or handle error
    End If
    
    'Debug.Print "Found in DistType: " & foundInDist
    'Debug.Print "Found in CalType: " & foundInCal


    Set GetTableRange = tableRange
    'Debug.Print "Table Range " & GetTableRange.Address
    'Debug.Print "Sheet Name: " & GetTableRange.Worksheet.Name
    
End Function


'This function will return the distribution values for the given distribution type from the distribution table. Will also use to get the calendar working days.
'Header will be either CalType or DistType
Function GetColumn(Header As String) As Variant
    Dim tableRange As Range
    Dim colIndex As Long
    Dim result() As Double
    Dim i As Long
    Dim dataRange As Range

    ' Get the full table range (including header row)
    Set tableRange = GetTableRange(Header)
    

    ' Find the column index for the header
    For colIndex = 1 To tableRange.Columns.Count
        If tableRange.Cells(1, colIndex).Value = Header Then
            Exit For
        End If
    Next colIndex

    ' If header not found
    If colIndex > tableRange.Columns.Count Then
        GetColumn = CVErr(xlErrNA)
        Exit Function
    End If

    ' Define the data range (excluding the header row)
    Set dataRange = tableRange.Offset(1, 0).Resize(tableRange.Rows.Count - 1)

    ' Resize result array
    ReDim result(1 To dataRange.Rows.Count)

    ' Fill result array with values from the column
    For i = 1 To dataRange.Rows.Count
        result(i) = dataRange.Cells(i, colIndex).Value
    Next i

    ' Return the result array
    GetColumn = result
End Function


'Array that holds the distribution percentages based on the duration. ie. If you have 10 days duration = 10 values, each a sum of the distribution values from the table multiplied to the resource.
'Distribution = GetColumn(CalType OR DistType)
Function SumByDistributions(Distribution As String, Duration As Double) As Variant
    Dim outputArray() As Double
    Dim i As Long, j As Long
    Dim groupSum As Double
    Dim inputArray() As Double
    inputArray = GetColumn(Distribution)
    'Dim NumOfDist As Double
    'NumOfDist = 100 / Duration
    'Dim groupCount As Long

    'groupCount = Int(UBound(inputArray) / NumOfDist)
    ReDim outputArray(0 To Duration - 1)

    For i = 0 To Duration - 1
        groupSum = 0
        For j = 1 To Duration
            groupSum = groupSum + inputArray(i * Duration + j)
        Next j
        outputArray(i) = groupSum
    Next i

    'This will sum the values in the inputArray by groups based on the Duration, then return the outputArray with the summed values.
    SumByDistributions = outputArray
End Function

'This function takes the product of Summed Distribution and resource and creates an array.
Function CreateDistributionArray(Duration As Double, Resourse As Double, Distribution As String) As Variant
    inputArray = SumByDistributions(Distribution, Duration)
    Dim i As Long
    Dim outputArray() As Double
    resource = Resourse

    'Calculate the number of distributions based on the duration
    'Duration = 100 / Duration
    
    'Resize the output array to hold the summed values
    ReDim outputArray(0 To Duration - 1)
    For i = 0 To Duration - 1
        'Multiply each summed distribution value by the resource value
        outputArray(i) = inputArray(i) * resource
        'Debug.Print "outputArray(" & i & ") = " & outputArray(i)
    Next i
    'Return the output array with the summed distribution values
    'Debug.Print TypeName(outputArray(0))
    CreateDistributionArray = outputArray
    'Debug.Print "Found in CalType: " & foundInCal
End Function

'Function that takes the distribution array (Resource value * summed distribution values, one per each duration) and then assigns each value in the array to the corresponding date based on the start and the duration. Need to take the start date, then look at the calendar selected, evaluate if a date is a working day, and if it is, assign the value to that date. If not, skip to the next date. And do the same thing for holidays. There are 6 caldnars to choose from, so the function will take the calendar name as a parameter. The output will be an array of values corresponding to each date in the duration, with zeroes for non-working days. If the name of the calendar contains "NoHol" then it will not check for holidays, just working days.

    'For each date in the start date + duration:
        'Check if the date is a working day:
            'Check if date is in the Holiday list:
                'If it is NOT, assign the corresponding value from the distribution array to that date.
            'If it is not, assign zero or skip as needed.
    'Move to the next date
    'Return the output array with assigned distribution values for each date in the duration.

Function AssignDistributionToDates(Start As Date, Duration As Double, DistributionArray As Variant, Calendar As String) As Variant
    Dim outputArray() As Double
    Dim i As Long
    Dim workingDayCount As Integer
    Dim calendarRange As Double
    Dim holidays As Range
    Dim calendarWorkDays As Variant
    Dim currentDateIndex As Integer
    Dim isWorkingDay As Boolean

    
    
    ReDim outputArray(0 To Duration * (7 / 5))

    currentDate = Start
    holidayRange = Range("Holidays")
    'calendarRange = GetColumn("CalType") will get the calendarWorkDays to work first
    calendarWorkDays = Array(1, 1, 1, 1, 1, 0, 0) ' Monday to Sunday

    i = 0
    Do While workingDayCount < Duration
        currentDateIndex = Weekday(currentDate, vbMonday) ' 1 = Monday, 7 = Sunday
    
        ' Default value
        outputArray(i) = 0
    
        ' Check if it's a working weekday
        If calendarWorkDays(currentDateIndex - 1) = 1 Then
            ' Check if it's a holiday
            isHoliday = Not IsError(Application.Match(currentDate, holidayRange, 0))
    
            If Not isHoliday Then
                ' It's a working day and not a holiday
                outputArray(i) = DistributionArray(workingDayCount)
                workingDayCount = workingDayCount + 1
                Debug.Print "Output Array(" & workingDayCount & "): " & DistributionArray(workingDayCount - 1)
                
                ' Only increment i if we assigned from DistributionArray
                
            Else
                Debug.Print "Output Array(" & workingDayCount & "): " & outputArray(i)
            End If
        Else
            Debug.Print "Output Array(" & workingDayCount & "): " & outputArray(i)
        End If
    
        ' Move to the next date regardless
        currentDate = currentDate + 1
        i = i + 1
    Loop


    'Return the output array with assigned distribution values for each date in the duration
    AssignDistributionToDates = outputArray
End Function

'This function will return the last column range starting from column J (10), where my dates start to the last used column in the first row. Should return the same row everytime.
Function GetLastColumnRange() As Range
    Dim lastCol As Long
    lastCol = Cells(1, Columns.Count).End(xlToLeft).Column
    Set GetLastColumnRange = Range(Cells(1, 10), Cells(1, lastCol)) ' Column 10 = J
End Function

'This function will find the cell that contains the target date in the specified search range. We will already be on the correct row so we want to return the column value of the cell that contains the date.
Function FindDateColumn(startDate As Date) As Variant
    Dim matchIndex As Variant
    Dim searchRange As Range
    Dim lastCol As Long
    

    ' Ensure startDate is a pure date
    startDate = DateValue(startDate)
    lastCol = Cells(1, Columns.Count).End(xlToLeft).Column

    ' Define the range (dates in row 1, columns J to DE)
    Set searchRange = Range(Cells(1, 10), Cells(1, lastCol)) ' J1 to DE1

    ' Use Match with exact match
    matchIndex = Application.Match(CLng(startDate), searchRange, 0)

    If IsError(matchIndex) Then
        FindDateColumn = CVErr(xlErrNA)
    Else
        ' Add 9 to align with your indexing logic
        FindDateColumn = matchIndex + 9
    End If
End Function

'This subroutine will take outputArray (the array that holds the distribution values) for each date in the duration
Sub WriteToCells()
    Dim currentCell As Range
    Dim distArray As Variant
    Dim resultArray As Variant
    Dim startingCol As Variant

    Dim Duration As Double
    Dim startDate As Date
    Dim finishDate As Date
    Dim resource As Double
    Dim distributionType As String
    Dim calendarType As String
    
    ActivateGanttSheet

    ' Loop through non-empty cells in column A
    For Each currentCell In Range("A2:A" & Cells(Rows.Count, 1).End(xlUp).Row)
        If Not IsEmpty(currentCell.Value) Then
            Dim currentRow As Long
            currentRow = currentCell.Row

            ' Get values from the same row
            Duration = Cells(currentRow, 3).Value          ' Column C
            startDate = Cells(currentRow, 4).Value         ' Column D
            finishDate = Cells(currentRow, 5).Value        ' Column E, this probably wont be used
            resource = Cells(currentRow, 6).Value          ' Column F
            distributionType = Cells(currentRow, 7).Value  ' Column G
            calendarType = Cells(currentRow, 8).Value      ' Column H

            ' Generate distribution and assign values
            distArray = CreateDistributionArray(Duration, resource, distributionType)
            resultArray = AssignDistributionToDates(startDate, Duration, distArray, calendarType)
            startingCol = FindDateColumn(startDate)

            ' Write resultArray to the row starting at startingCol
            Dim i As Long
            For i = LBound(resultArray) To UBound(resultArray)
                Cells(currentRow, startingCol + i - 1).Value = resultArray(i)
            Next i
        End If
    Next currentCell
End Sub

