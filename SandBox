Private Sub ResetButton_Click()
    Dim response As VbMsgBoxResult
    Dim cancelresponse As VbMsgBoxResult
    ' First check if there are any exportable sheets
    If ExportSheetsExist Then
        response = MsgBox("This will reset the worksheet data, including removing any exported tabs. Proceed?", vbYesNo + vbQuestion, "Confirm Action")
        
        If response = vbYes Then
            ' Proceed with reset
            Call InitializeColumnIndex
            Set plotWS = ThisWorkbook.Sheets("Plot")
            ResetButton.Enabled = False
            Call ClearFromJ2
            plotWS.Cells.ClearContents
        Else
            ' Offer to export plots before canceling
            cancelresponse = MsgBox("Would you like to export your plots before canceling?", vbYesNo + vbQuestion, "Export Option")
            
            If cancelresponse = vbYes Then
                Call MoveSheetsExceptSpecified
            Else
                MsgBox "Action canceled.", vbExclamation
            End If
        End If
    Else
        ' No exportable sheets, just clear the form
        Call ClearFromJ2
    End If
End Sub