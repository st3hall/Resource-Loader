Private Sub UserForm_Initialize()
    Dim dpiScale As Double
    dpiScale = Application.Width / 1024 ' Assuming 1024 is your design baseline

    ' Resize the form
    Me.Width = Me.Width * dpiScale
    Me.Height = Me.Height * dpiScale

    ' Center the form
    Me.Left = (Application.Width - Me.Width) / 2
    Me.Top = (Application.Height - Me.Height) / 2

    ' Resize controls
    Dim ctrl As Control
    For Each ctrl In Me.Controls
        ctrl.Width = ctrl.Width * dpiScale
        ctrl.Height = ctrl.Height * dpiScale
        ctrl.Left = ctrl.Left * dpiScale
        ctrl.Top = ctrl.Top * dpiScale
        ctrl.Font.Size = ctrl.Font.Size * dpiScale
    Next ctrl
End Sub

Sub SumValuesByDate()
    Dim dateRange As Range
    Dim resultArray() As Variant
    Dim i As Long, colIndex As Long
    Dim ws As Worksheet
    Dim targetWS As Worksheet
    Dim lastRow As Long
    Dim cumulativeSum As Double
    cumulativeSum = 0
    Dim startingCol As Long
    startingCol = 10 ' Column J

    Set ws = ThisWorkbook.Sheets("Gantt")
    Set dateRange = GetLastColumnRange()

    If SheetExists("Plot") Then
        Set targetWS = ThisWorkbook.Sheets("Plot")
    Else
        MsgBox "Sheet 'Plot' does not exist!"
        Exit Sub
    End If

    ReDim resultArray(1 To dateRange.Columns.Count, 1 To 2)

    ' Variables for stats
    Dim maxVal As Double, minVal As Double, totalSum As Double
    Dim maxDate As Variant, minDate As Variant
    maxVal = -1E+308
    minVal = 1E+308
    totalSum = 0

    For i = 1 To dateRange.Columns.Count
        colIndex = startingCol + (i - 1)
        lastRow = ws.Cells(ws.Rows.Count, colIndex).End(xlUp).Row

        Dim currentSum As Double
        currentSum = 0

        Dim r As Long
        For r = 2 To lastRow
            If IsNumeric(ws.Cells(r, colIndex).Value) Then
                currentSum = currentSum + ws.Cells(r, colIndex).Value
            End If
        Next r

        cumulativeSum = cumulativeSum + currentSum
        totalSum = totalSum + cumulativeSum

        resultArray(i, 1) = ws.Cells(1, colIndex).Value ' Date
        resultArray(i, 2) = cumulativeSum               ' Cumulative Sum

        ' Track max and min
        If cumulativeSum > maxVal Then
            maxVal = cumulativeSum
            maxDate = ws.Cells(1, colIndex).Value
        End If

        If cumulativeSum < minVal Then
            minVal = cumulativeSum
            minDate = ws.Cells(1, colIndex).Value
        End If
    Next i

    ' Output result to Plot sheet starting at A2
    targetWS.Range("A2:B" & targetWS.Cells(targetWS.Rows.Count, "A").End(xlUp).Row).ClearContents
    targetWS.Range("A2").Resize(UBound(resultArray), 2).Value = resultArray

    ' Write directly to TextBoxes on Sheet1
    With ThisWorkbook.Sheets("Sheet1")
        .AveBox.Text = Format(totalSum / dateRange.Columns.Count, "0.00")
        .MaxBox.Text = maxVal
        .MaxDate.Text = maxDate
        .MinBox.Text = minVal
        .MinDate.Text = minDate
    End With
End Sub


