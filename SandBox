Sub PopulateDateHeaders()
    Dim ws As Worksheet
    Set ws = ThisWorkbook.Sheets("Gantt")

    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, "D").End(xlUp).Row ' Start dates in column D

    Dim earliestStart As Date
    Dim latestFinish As Date
    Dim i As Long

    ' Initialize with first valid start date
    earliestStart = ws.Cells(2, "D").Value
    latestFinish = earliestStart

    For i = 2 To lastRow
        If IsDate(ws.Cells(i, "D").Value) And IsNumeric(ws.Cells(i, "C").Value) Then
            Dim startDate As Date
            Dim duration As Double
            Dim finishDate As Date

            startDate = ws.Cells(i, "D").Value
            duration = ws.Cells(i, "C").Value
            finishDate = startDate + (duration * 7 / 5)

            If startDate < earliestStart Then earliestStart = startDate
            If finishDate > latestFinish Then latestFinish = finishDate
        End If
    Next i

    ' Write dates to row 1 starting at column J
    Dim currentDate As Date
    currentDate = earliestStart

    Dim col As Long
    col = 10 ' Column J

    Do While currentDate <= latestFinish
        ws.Cells(1, col).Value = currentDate
        ws.Cells(1, col).NumberFormat = "mm/dd/yyyy"
        currentDate = currentDate + 1
        col = col + 1
    Loop
End Sub


